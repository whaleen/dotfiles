  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "{{COMMENT}}", "fontStyle": "italic" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "string constant.other.placeholder"],
      "settings": { "foreground": "{{FG}}" }
    },
    {
      "name": "Function Parameter",
      "scope": ["variable.parameter", "meta.function.parameters"],
      "settings": { "foreground": "{{SUBTLE}}", "fontStyle": "italic" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "{{BRIGHT_RED}}" }
    },
    {
      "name": "Keyword, Storage",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "{{BLUE}}" }
    },
    {
      "name": "Operator, Control",
      "scope": [
        "keyword.control", "keyword.operator",
        "punctuation.section.embedded", "keyword.other.template",
        "keyword.other.substitution"
      ],
      "settings": { "foreground": "{{SUBTLE}}" }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "{{ACCENT}}" }
    },
    {
      "name": "HTML/JSX Tag punctuation",
      "scope": [
        "punctuation.definition.tag", "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin", "punctuation.definition.tag.end"
      ],
      "settings": { "foreground": "{{DIM}}" }
    },
    {
      "name": "Function, Special Method",
      "scope": [
        "entity.name.function", "variable.function",
        "support.function", "keyword.other.special-method"
      ],
      "settings": { "foreground": "{{ACCENT}}" }
    },
    {
      "name": "Number, Constant, Boolean",
      "scope": [
        "constant.numeric", "constant.language", "support.constant",
        "constant.character", "constant.escape", "keyword.other.unit"
      ],
      "settings": { "foreground": "{{BRIGHT_GREEN}}" }
    },
    {
      "name": "String, Symbols",
      "scope": [
        "string", "constant.other.symbol", "constant.other.key"
      ],
      "settings": { "foreground": "{{GREEN}}" }
    },
    {
      "name": "Type, Class, Support",
      "scope": [
        "entity.name.type", "entity.name.class", "support.type",
        "support.class", "support.type.sys-types"
      ],
      "settings": { "foreground": "{{MAGENTA}}" }
    },
    {
      "name": "Namespace, Module",
      "scope": [
        "entity.name.namespace", "entity.name.module",
        "support.other.namespace", "meta.use"
      ],
      "settings": { "foreground": "{{CYAN}}" }
    },
    {
      "name": "Decorator, Annotation",
      "scope": [
        "entity.name.function.decorator", "meta.decorator",
        "punctuation.decorator", "storage.type.annotation"
      ],
      "settings": { "foreground": "{{YELLOW}}", "fontStyle": "italic" }
    },
    {
      "name": "CSS Property",
      "scope": [
        "support.type.property-name", "meta.property-name",
        "support.type.vendored.property-name"
      ],
      "settings": { "foreground": "{{SUBTLE}}" }
    },
    {
      "name": "CSS Value, Unit",
      "scope": ["support.constant.property-value", "keyword.other.unit"],
      "settings": { "foreground": "{{FG}}" }
    },
    {
      "name": "Language methods (this, self)",
      "scope": ["variable.language"],
      "settings": { "foreground": "{{BLUE}}", "fontStyle": "italic" }
    },
    {
      "name": "Attribute name",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "{{SUBTLE}}" }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "text.html.basic entity.other.attribute-name.html",
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": { "foreground": "{{ACCENT}}" }
    },
    {
      "name": "CSS Class/ID",
      "scope": [
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id"
      ],
      "settings": { "foreground": "{{ACCENT}}" }
    },
    {
      "name": "Import / Export keyword",
      "scope": [
        "keyword.control.import", "keyword.control.export",
        "keyword.control.from", "keyword.control.as"
      ],
      "settings": { "foreground": "{{MAGENTA}}" }
    },
    {
      "name": "Inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "{{GREEN}}" }
    },
    {
      "name": "Deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "{{RED}}" }
    },
    {
      "name": "Changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "{{YELLOW}}" }
    },
    {
      "name": "Regular Expression",
      "scope": ["string.regexp"],
      "settings": { "foreground": "{{CYAN}}" }
    },
    {
      "name": "Escape Character",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "{{MAGENTA}}" }
    },
    {
      "name": "URL",
      "scope": ["*url*", "*link*", "*uri*"],
      "settings": { "fontStyle": "underline" }
    },
    {
      "name": "JSON Key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "{{ACCENT}}" }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading", "markup.heading entity.name"],
      "settings": { "foreground": "{{ACCENT}}", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Plain",
      "scope": ["text.html.markdown", "punctuation.definition.list_item.markdown"],
      "settings": { "foreground": "{{FG}}" }
    },
    {
      "name": "Markdown Raw Inline",
      "scope": ["text.html.markdown markup.inline.raw.markdown"],
      "settings": { "foreground": "{{GREEN}}" }
    },
    {
      "name": "Markup Bold",
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold", "foreground": "{{FG}}" }
    },
    {
      "name": "Markup Italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic", "foreground": "{{FG}}" }
    },
    {
      "name": "Markup Underline",
      "scope": ["markup.underline"],
      "settings": { "fontStyle": "underline", "foreground": "{{ACCENT}}" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace":           "{{CYAN}}",
    "class":               "{{MAGENTA}}",
    "enum":                "{{MAGENTA}}",
    "interface":           "{{MAGENTA}}",
    "struct":              "{{MAGENTA}}",
    "typeParameter":       "{{MAGENTA}}",
    "type":                "{{MAGENTA}}",
    "function":            "{{ACCENT}}",
    "method":              "{{ACCENT}}",
    "decorator":           { "foreground": "{{YELLOW}}", "italic": true },
    "parameter":           { "foreground": "{{SUBTLE}}", "italic": true },
    "variable":            "{{FG}}",
    "variable.readonly":   "{{BRIGHT_GREEN}}",
    "property":            "{{FG}}",
    "property.readonly":   "{{SUBTLE}}",
    "enumMember":          "{{BRIGHT_GREEN}}",
    "event":               "{{YELLOW}}",
    "macro":               "{{CYAN}}",
    "label":               "{{SUBTLE}}",
    "comment":             { "foreground": "{{COMMENT}}", "italic": true },
    "string":              "{{GREEN}}",
    "number":              "{{BRIGHT_GREEN}}",
    "regexp":              "{{CYAN}}",
    "operator":            "{{SUBTLE}}",
    "keyword":             "{{BLUE}}",
    "keyword.import":      "{{MAGENTA}}"
  }
}
