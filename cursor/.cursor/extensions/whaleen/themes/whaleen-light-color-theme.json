  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#AAAABC", "fontStyle": "italic" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "string constant.other.placeholder"],
      "settings": { "foreground": "#1A1A2E" }
    },
    {
      "name": "Function Parameter",
      "scope": ["variable.parameter", "meta.function.parameters"],
      "settings": { "foreground": "#555566", "fontStyle": "italic" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#CC4A38" }
    },
    {
      "name": "Keyword, Storage",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#5A4FA0" }
    },
    {
      "name": "Operator, Control",
      "scope": [
        "keyword.control", "keyword.operator",
        "punctuation.section.embedded", "keyword.other.template",
        "keyword.other.substitution"
      ],
      "settings": { "foreground": "#555566" }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#7C5CBF" }
    },
    {
      "name": "HTML/JSX Tag punctuation",
      "scope": [
        "punctuation.definition.tag", "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin", "punctuation.definition.tag.end"
      ],
      "settings": { "foreground": "#888899" }
    },
    {
      "name": "Function, Special Method",
      "scope": [
        "entity.name.function", "variable.function",
        "support.function", "keyword.other.special-method"
      ],
      "settings": { "foreground": "#7C5CBF" }
    },
    {
      "name": "Number, Constant, Boolean",
      "scope": [
        "constant.numeric", "constant.language", "support.constant",
        "constant.character", "constant.escape", "keyword.other.unit"
      ],
      "settings": { "foreground": "#20A070" }
    },
    {
      "name": "String, Symbols",
      "scope": [
        "string", "constant.other.symbol", "constant.other.key"
      ],
      "settings": { "foreground": "#2E6B50" }
    },
    {
      "name": "Type, Class, Support",
      "scope": [
        "entity.name.type", "entity.name.class", "support.type",
        "support.class", "support.type.sys-types"
      ],
      "settings": { "foreground": "#8C3A78" }
    },
    {
      "name": "Namespace, Module",
      "scope": [
        "entity.name.namespace", "entity.name.module",
        "support.other.namespace", "meta.use"
      ],
      "settings": { "foreground": "#A03060" }
    },
    {
      "name": "Decorator, Annotation",
      "scope": [
        "entity.name.function.decorator", "meta.decorator",
        "punctuation.decorator", "storage.type.annotation"
      ],
      "settings": { "foreground": "#8C5E20", "fontStyle": "italic" }
    },
    {
      "name": "CSS Property",
      "scope": [
        "support.type.property-name", "meta.property-name",
        "support.type.vendored.property-name"
      ],
      "settings": { "foreground": "#555566" }
    },
    {
      "name": "CSS Value, Unit",
      "scope": ["support.constant.property-value", "keyword.other.unit"],
      "settings": { "foreground": "#1A1A2E" }
    },
    {
      "name": "Language methods (this, self)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#5A4FA0", "fontStyle": "italic" }
    },
    {
      "name": "Attribute name",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#555566" }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "text.html.basic entity.other.attribute-name.html",
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": { "foreground": "#7C5CBF" }
    },
    {
      "name": "CSS Class/ID",
      "scope": [
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id"
      ],
      "settings": { "foreground": "#7C5CBF" }
    },
    {
      "name": "Import / Export keyword",
      "scope": [
        "keyword.control.import", "keyword.control.export",
        "keyword.control.from", "keyword.control.as"
      ],
      "settings": { "foreground": "#8C3A78" }
    },
    {
      "name": "Inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#2E6B50" }
    },
    {
      "name": "Deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#B34030" }
    },
    {
      "name": "Changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#8C5E20" }
    },
    {
      "name": "Regular Expression",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#A03060" }
    },
    {
      "name": "Escape Character",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#8C3A78" }
    },
    {
      "name": "URL",
      "scope": ["*url*", "*link*", "*uri*"],
      "settings": { "fontStyle": "underline" }
    },
    {
      "name": "JSON Key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#7C5CBF" }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading", "markup.heading entity.name"],
      "settings": { "foreground": "#7C5CBF", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Plain",
      "scope": ["text.html.markdown", "punctuation.definition.list_item.markdown"],
      "settings": { "foreground": "#1A1A2E" }
    },
    {
      "name": "Markdown Raw Inline",
      "scope": ["text.html.markdown markup.inline.raw.markdown"],
      "settings": { "foreground": "#2E6B50" }
    },
    {
      "name": "Markup Bold",
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold", "foreground": "#1A1A2E" }
    },
    {
      "name": "Markup Italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic", "foreground": "#1A1A2E" }
    },
    {
      "name": "Markup Underline",
      "scope": ["markup.underline"],
      "settings": { "fontStyle": "underline", "foreground": "#7C5CBF" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace":           "#A03060",
    "class":               "#8C3A78",
    "enum":                "#8C3A78",
    "interface":           "#8C3A78",
    "struct":              "#8C3A78",
    "typeParameter":       "#8C3A78",
    "type":                "#8C3A78",
    "function":            "#7C5CBF",
    "method":              "#7C5CBF",
    "decorator":           { "foreground": "#8C5E20", "italic": true },
    "parameter":           { "foreground": "#555566", "italic": true },
    "variable":            "#1A1A2E",
    "variable.readonly":   "#20A070",
    "property":            "#1A1A2E",
    "property.readonly":   "#555566",
    "enumMember":          "#20A070",
    "event":               "#8C5E20",
    "macro":               "#A03060",
    "label":               "#555566",
    "comment":             { "foreground": "#AAAABC", "italic": true },
    "string":              "#2E6B50",
    "number":              "#20A070",
    "regexp":              "#A03060",
    "operator":            "#555566",
    "keyword":             "#5A4FA0",
    "keyword.import":      "#8C3A78"
  }
}
