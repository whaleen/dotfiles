  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#505050", "fontStyle": "italic" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "string constant.other.placeholder"],
      "settings": { "foreground": "#ffffff" }
    },
    {
      "name": "Function Parameter",
      "scope": ["variable.parameter", "meta.function.parameters"],
      "settings": { "foreground": "#A0A0A0", "fontStyle": "italic" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#ff8080" }
    },
    {
      "name": "Keyword, Storage",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#aca1cf" }
    },
    {
      "name": "Operator, Control",
      "scope": [
        "keyword.control", "keyword.operator",
        "punctuation.section.embedded", "keyword.other.template",
        "keyword.other.substitution"
      ],
      "settings": { "foreground": "#A0A0A0" }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#C3A6FF" }
    },
    {
      "name": "HTML/JSX Tag punctuation",
      "scope": [
        "punctuation.definition.tag", "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin", "punctuation.definition.tag.end"
      ],
      "settings": { "foreground": "#7E7E7E" }
    },
    {
      "name": "Function, Special Method",
      "scope": [
        "entity.name.function", "variable.function",
        "support.function", "keyword.other.special-method"
      ],
      "settings": { "foreground": "#C3A6FF" }
    },
    {
      "name": "Number, Constant, Boolean",
      "scope": [
        "constant.numeric", "constant.language", "support.constant",
        "constant.character", "constant.escape", "keyword.other.unit"
      ],
      "settings": { "foreground": "#99FFE4" }
    },
    {
      "name": "String, Symbols",
      "scope": [
        "string", "constant.other.symbol", "constant.other.key"
      ],
      "settings": { "foreground": "#90b99f" }
    },
    {
      "name": "Type, Class, Support",
      "scope": [
        "entity.name.type", "entity.name.class", "support.type",
        "support.class", "support.type.sys-types"
      ],
      "settings": { "foreground": "#e29eca" }
    },
    {
      "name": "Namespace, Module",
      "scope": [
        "entity.name.namespace", "entity.name.module",
        "support.other.namespace", "meta.use"
      ],
      "settings": { "foreground": "#ea83a5" }
    },
    {
      "name": "Decorator, Annotation",
      "scope": [
        "entity.name.function.decorator", "meta.decorator",
        "punctuation.decorator", "storage.type.annotation"
      ],
      "settings": { "foreground": "#e6b99d", "fontStyle": "italic" }
    },
    {
      "name": "CSS Property",
      "scope": [
        "support.type.property-name", "meta.property-name",
        "support.type.vendored.property-name"
      ],
      "settings": { "foreground": "#A0A0A0" }
    },
    {
      "name": "CSS Value, Unit",
      "scope": ["support.constant.property-value", "keyword.other.unit"],
      "settings": { "foreground": "#ffffff" }
    },
    {
      "name": "Language methods (this, self)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#aca1cf", "fontStyle": "italic" }
    },
    {
      "name": "Attribute name",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#A0A0A0" }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "text.html.basic entity.other.attribute-name.html",
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": { "foreground": "#C3A6FF" }
    },
    {
      "name": "CSS Class/ID",
      "scope": [
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id"
      ],
      "settings": { "foreground": "#C3A6FF" }
    },
    {
      "name": "Import / Export keyword",
      "scope": [
        "keyword.control.import", "keyword.control.export",
        "keyword.control.from", "keyword.control.as"
      ],
      "settings": { "foreground": "#e29eca" }
    },
    {
      "name": "Inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#90b99f" }
    },
    {
      "name": "Deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#f5a191" }
    },
    {
      "name": "Changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#e6b99d" }
    },
    {
      "name": "Regular Expression",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#ea83a5" }
    },
    {
      "name": "Escape Character",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#e29eca" }
    },
    {
      "name": "URL",
      "scope": ["*url*", "*link*", "*uri*"],
      "settings": { "fontStyle": "underline" }
    },
    {
      "name": "JSON Key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#C3A6FF" }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading", "markup.heading entity.name"],
      "settings": { "foreground": "#C3A6FF", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Plain",
      "scope": ["text.html.markdown", "punctuation.definition.list_item.markdown"],
      "settings": { "foreground": "#ffffff" }
    },
    {
      "name": "Markdown Raw Inline",
      "scope": ["text.html.markdown markup.inline.raw.markdown"],
      "settings": { "foreground": "#90b99f" }
    },
    {
      "name": "Markup Bold",
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold", "foreground": "#ffffff" }
    },
    {
      "name": "Markup Italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic", "foreground": "#ffffff" }
    },
    {
      "name": "Markup Underline",
      "scope": ["markup.underline"],
      "settings": { "fontStyle": "underline", "foreground": "#C3A6FF" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace":           "#ea83a5",
    "class":               "#e29eca",
    "enum":                "#e29eca",
    "interface":           "#e29eca",
    "struct":              "#e29eca",
    "typeParameter":       "#e29eca",
    "type":                "#e29eca",
    "function":            "#C3A6FF",
    "method":              "#C3A6FF",
    "decorator":           { "foreground": "#e6b99d", "italic": true },
    "parameter":           { "foreground": "#A0A0A0", "italic": true },
    "variable":            "#ffffff",
    "variable.readonly":   "#99FFE4",
    "property":            "#ffffff",
    "property.readonly":   "#A0A0A0",
    "enumMember":          "#99FFE4",
    "event":               "#e6b99d",
    "macro":               "#ea83a5",
    "label":               "#A0A0A0",
    "comment":             { "foreground": "#505050", "italic": true },
    "string":              "#90b99f",
    "number":              "#99FFE4",
    "regexp":              "#ea83a5",
    "operator":            "#A0A0A0",
    "keyword":             "#aca1cf",
    "keyword.import":      "#e29eca"
  }
}
