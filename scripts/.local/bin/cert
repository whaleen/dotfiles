#!/bin/bash
# cert - Quickly generate and copy cntx-ui certification prompts

PROMPTS_DIR="$HOME/Projects/cntx-prompts"
PROJECTS_ROOT="$HOME/Projects"

# 1. Pick a project
PROJECT_PATH=$(find "$PROJECTS_ROOT" -maxdepth 2 -type d | grep -vE "/\.|node_modules|dist|target" | fzf --prompt="Select Project > ")

if [ -z "$PROJECT_PATH" ]; then
  echo "No project selected."
  exit 1
fi

PROJECT_NAME=$(basename "$PROJECT_PATH")

# 2. Pick a prompt template
TEMPLATE=$(ls "$PROMPTS_DIR"/*.md | fzf --prompt="Select Prompt Template > ")

if [ -z "$TEMPLATE" ]; then
  echo "No template selected."
  exit 1
fi

# 3. Get latest version from npm
VERSION=$(npm view cntx-ui version)

# 4. Inject variables and copy to clipboard
cat "$TEMPLATE" \
  | sed "s|\[PROJECT NAME\]|$PROJECT_NAME|g" \
  | sed "s|\[PATH\]|${PROJECT_PATH#$PROJECTS_ROOT/}|g" \
  | sed "s|\[VERSION\]|$VERSION|g" \
  | pbcopy

echo "✅ Prompt for '$PROJECT_NAME' (v$VERSION) copied to clipboard!"
