prefix_rule(pattern=["node", "-e", "(async()=>{const r=await fetch('http://[::1]:3333/assets/index-DAunWqbX.js');const t=await r.text();const pats=['agent/discover','agent/query','agent/investigate','artifacts/summarize','/api/','mcp'];for(const p of pats){console.log(p, t.includes(p));}const m=[...t.matchAll(/\\b(agent\\/[a-zA-Z0-9_-]+|artifacts\\/[a-zA-Z0-9_-]+|\\/api\\/[a-zA-Z0-9_\\/-]+)\\b/g)].map(x=>x[1]);const uniq=[...new Set(m)];console.log('matches',uniq.length);for(const s of uniq.slice(0,120))console.log(s);} )();"], decision="allow")
