prefix_rule(pattern=["npm", "run", "npc:dev"], decision="allow")
prefix_rule(pattern=["npm", "run", "dev"], decision="allow")
prefix_rule(pattern=["npm", "run", "functions:dev"], decision="allow")
prefix_rule(pattern=["npx", "tsx", "-e", "import { getMiningEnergyCost, getPowerCoreCapacity } from './src/lib/game-logic/mining.ts'; const samples=[{level:1,health:100,experience:0,energy:20},{level:10,health:40,experience:5000,energy:50},{level:25,health:85,experience:12000,energy:80}]; for (const s of samples){ console.log(JSON.stringify({input:s, energyCost:getMiningEnergyCost(s), maxEnergy:getPowerCoreCapacity(s)})); }"], decision="allow")
prefix_rule(pattern=["curl", "-i", "-X", "OPTIONS", "http://localhost:8888/.netlify/functions/mine-action"], decision="allow")
prefix_rule(pattern=["npx", "tsx", "-e", "import { getMiningEnergyCost, getPowerCoreCapacity } from './src/lib/game-logic/mining.ts'; const input={level:10,health:40,experience:5000}; console.log('shared', getMiningEnergyCost(input), getPowerCoreCapacity(input));"], decision="allow")
prefix_rule(pattern=["curl", "-s", "-i", "-X", "POST", "http://localhost:8888/.netlify/functions/mine-action", "-H", "Content-Type: application/json", "-d", "{\"wallet_address\":\"11111111111111111111111111111111\"}"], decision="allow")
prefix_rule(pattern=["npx", "tsx", "-e", "import { generateChatMessage, applyDamage, checkDeath, applyConsequence, calculateTravelHealthCost, validateTrade } from './src/lib/game-logic/actions.ts'; console.log('chat', generateChatMessage({personality:'friendly', random:() => 0})); console.log('damage', applyDamage(20, 7)); console.log('death', checkDeath(0, 10)); console.log('consequence', applyConsequence({health:-5, energy:4, credits:12, item:'ore', story_flag:'intro_done', next_event_id:'evt_2'}, {health:50, energy:40, experience:10, earth:100, inventory:[], storyFlags:[]})); console.log('travelCost', calculateTravelHealthCost(2,5)); console.log('trade', validateTrade(10, 15));"], decision="allow")
prefix_rule(pattern=["curl", "-s", "-i", "http://localhost:8888/.netlify/functions/story-list?entity=story"], decision="allow")
prefix_rule(pattern=["curl", "-s", "-i", "-X", "POST", "http://localhost:8888/.netlify/functions/story-create", "-H", "Content-Type: application/json", "-H", "x-admin-wallet: FuuSf9DtXVA1etWYkBZFdEkxYKcHWYUMjNLsc287z3eh", "-d", "{\"entity\":\"consequence\",\"data\":{\"choice_id\":\"11111111-1111-1111-1111-111111111111\",\"consequence_data\":{\"health\":1,\"bad_key\":42}}}"], decision="allow")
prefix_rule(pattern=["curl", "-s", "-i", "http://localhost:8888/.netlify/functions/story-list?entity=story", "-H", "x-admin-wallet: FuuSf9DtXVA1etWYkBZFdEkxYKcHWYUMjNLsc287z3eh"], decision="allow")
prefix_rule(pattern=["curl", "-s", "-i", "http://localhost:8888/.netlify/functions/get-locations"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "gh repo list --limit 1000 --json nameWithOwner,name,owner,visibility,isPrivate,isFork,isArchived,updatedAt,url,sshUrl,description --jq '( [\"nameWithOwner\",\"name\",\"owner\",\"visibility\",\"isPrivate\",\"isFork\",\"isArchived\",\"updatedAt\",\"url\",\"sshUrl\",\"description\"] | @csv), (.[] | [ .nameWithOwner, .name, .owner.login, .visibility, (.isPrivate|tostring), (.isFork|tostring), (.isArchived|tostring), .updatedAt, .url, .sshUrl, ((.description // \"\") | gsub(\"\\\\r|\\\\n\"; \" \")) ] | @csv)' > repos.csv && echo \"wrote $(pwd)/repos.csv\" && wc -l repos.csv"], decision="allow")
prefix_rule(pattern=["ditto"], decision="allow")
prefix_rule(pattern=["git", "clone", "https://github.com/whaleen/cntx-ui.git"], decision="allow")
prefix_rule(pattern=["gh", "auth", "status"], decision="allow")
prefix_rule(pattern=["gh", "issue", "create", "-R", "whaleen/cntx-ui", "--title", "ESM runtime crash: require(...) is used in MCP/API modules", "--body-file", "/tmp/cntx-issues/1-esm-require-crash.md"], decision="allow")
prefix_rule(pattern=["gh", "release", "list", "-R", "whaleen/cntx-ui", "--limit", "30"], decision="allow")
prefix_rule(pattern=["gh", "api", "repos/whaleen/cntx-ui/contributors", "--paginate", "--jq", ".[].login"], decision="allow")
prefix_rule(pattern=["rm", "-rf", "cntx-ui-mirror"], decision="allow")
prefix_rule(pattern=["git", "-C", "/Users/josh/Projects/_whaleen/screenboard", "fetch"], decision="allow")
prefix_rule(pattern=["git", "-C", "/Users/josh/Projects/_whaleen/screenboard", "pull", "--ff-only"], decision="allow")
prefix_rule(pattern=["pnpm", "-C", "/Users/josh/Projects/_whaleen/screenboard/packages/cli", "link", "--global"], decision="allow")
prefix_rule(pattern=["pnpm", "link", "--global"], decision="allow")
prefix_rule(pattern=["pnpm", "-C", "/Users/josh/Projects/_whaleen/screenboard", "install"], decision="allow")
prefix_rule(pattern=["npx", "playwright", "install", "chromium"], decision="allow")
prefix_rule(pattern=["pnpm", "-C", "/Users/josh/Projects/_whaleen/screenboard", "exec", "playwright", "install", "chromium"], decision="allow")
prefix_rule(pattern=["pnpm", "-C", "/Users/josh/Projects/_whaleen/screenboard/packages/cli", "exec", "playwright", "install", "chromium"], decision="allow")
